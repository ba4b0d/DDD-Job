# Required: secret used to sign JWTs (>= 32 chars recommended)
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-with-secrets-token-urlsafe-48

# Comma-separated list of allowed CORS origins.
# Examples:
#   CORS_ORIGINS=https://ba4b0d.qzz.io
#   CORS_ORIGINS=http://localhost:5173,http://192.168.100.9:5173
#   CORS_ORIGINS=                  (no extra origins — defaults to localhost + 192.168.100.9 only)
CORS_ORIGINS=
